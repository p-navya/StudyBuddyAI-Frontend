## Backend (StudyBuddyAI-Backend)

### Server Setup

```text
startup:
  load .env
  create express app

  configure CORS:
    allowedOrigins = [
      "http://localhost:5173",
      "https://studybuddy-project.vercel.app",
      FRONTEND_URL from env
    ] (non-empty)

    for each request:
      origin = request origin without trailing "/"
      if origin in normalized allowedOrigins:
        allow
      else:
        log "CORS blocked origin" and reject

  use JSON and urlencoded parsers (limit 50mb)

  test Supabase connection:
    attempt simple select from "users" table
    log success or error

  mount routers:
    "/api/auth"      -> authRoutes
    "/api/users"     -> userRoutes
    "/api/admin"     -> adminRoutes
    "/api/chatbot"   -> chatbotRoutes
    "/api/resources" -> resourceRoutes
    "/api/groups"    -> groupRoutes
    "/api/activity"  -> activityRoutes
    "/api/quizzes"   -> quizRoutes
    "/api/tasks"     -> taskRoutes

  GET "/api/health":
    return { status: "OK", message, timestamp }

  error middleware:
    log stack
    respond { success: false, message, optional stack in dev }

  404 handler:
    respond { success: false, message: "Route not found" }

  listen on PORT (env.PORT or 5000)
```

### Auth Middleware

```text
protect(req, res, next):
  read Authorization header
  if header starts with "Bearer ":
    token = second part
    try:
      decoded = jwt.verify(token, secret)
      user = Supabase "users".select(id, name, email, role).eq(id, decoded.id).single()
      if user missing:
        respond 401 "User not found"
      else:
        req.user = user
        next()
    catch:
      respond 401 "Not authorized, token failed"
  else:
    respond 401 "Not authorized, no token"
```

```text
authorize(...roles):
  return (req, res, next):
    if req.user.role not in roles:
      respond 403 "User role '<role>' is not authorized"
    else:
      next()
```

### Auth Controller

```text
POST /api/auth/register

register(req, res):
  { name, email, password } = body
  if any missing:
    respond 400 "Please provide all required fields"

  existingUser = Supabase users where email == given email
  if exists:
    respond 400 "User already exists with this email"

  hashedPassword = bcrypt.hash(password)

  user = insert into users:
    { name, email, password: hashedPassword, role: "student" }
  if error:
    respond 400 with DB message

  sendWelcomeEmail(email, name) asynchronously

  token = jwt.sign(
    { id: user.id, email: user.email, role: "authenticated", user_role: user.role },
    secret,
    expiresIn = 7d or env.JWT_EXPIRE
  )

  remove password from user object

  respond 201 with:
    success: true
    message: "User registered successfully"
    data: { token, user: userWithoutPassword }
```

```text
POST /api/auth/login

login(req, res):
  { email, password } = body
  if missing:
    respond 400 "Please provide email and password"

  user = Supabase users where email == given email
  if not found:
    respond 401 "Invalid credentials"

  if !bcrypt.compare(password, user.password):
    respond 401 "Invalid credentials"

  token = jwt.sign(
    { id: user.id, email: user.email, role: "authenticated", user_role: user.role },
    secret,
    expiresIn = 7d or env.JWT_EXPIRE
  )

  userWithoutPassword = user minus password

  respond 200 with:
    success: true
    message: "Login successful"
    data: {
      token,
      user: userWithoutPassword,
      firstLogin: user.first_login or false
    }
```

```text
GET /api/auth/me  (protected)

getMe(req, res):
  user = Supabase users.select(id, name, email, role, avatar, first_login, created_at)
                       .where id == req.user.id
  if missing:
    respond 404 "User not found"
  else:
    respond 200 with:
      success: true
      data: {
        user,
        firstLogin: user.first_login or false
      }
```

```text
POST /api/auth/forgot-password

forgotPassword(req, res):
  email = body.email
  if missing:
    respond 400 "Please provide an email"

  user = Supabase users where email == email

  if not found:
    // don't leak existence in real apps
    respond 200 "If an account exists, a reset link has been sent."

  resetToken = random hex string
  // (would be saved to DB with expiry in production)

  emailSent = sendPasswordResetEmail(user.email, resetToken, user.name)

  respond 200 with:
    success: true
    message: emailSent ? "Reset link sent to email" : "Failed to send email"
```

### Admin Controller & Routes

```text
adminRoutes:
  use(protect)
  use(authorize("admin"))

  GET  "/stats"   -> getStats
  POST "/mentors" -> createMentor
  GET  "/mentors" -> getMentors
```

```text
getStats(req, res):
  studentCount = count users where role == "student"
  mentorCount  = count users where role == "mentor"
  adminCount   = count users where role == "admin"

  respond 200 with:
    success: true
    data: {
      students: studentCount or 0,
      mentors: mentorCount or 0,
      admins: adminCount or 0,
      total: sum
    }
```

```text
createMentor(req, res):
  { name, email, password } = body
  if any missing:
    respond 400 "Please provide name, email, and password"

  if existing user with email:
    respond 400 "User already exists with this email"

  hashedPassword = bcrypt.hash(password)

  mentor = insert into users:
    { name, email, password: hashedPassword, role: "mentor", first_login: true }
  if error:
    respond 400 with DB message

  emailSent = sendMentorCredentialsEmail({ mentorName: name, email, password })

  respond 201 with:
    success: true
    message: "Mentor created successfully" + email status suffix
    data: { mentor, emailSent }
```

```text
getMentors(req, res):
  mentors = users where role == "mentor" ordered by created_at desc
  if error:
    respond 400 with message
  else:
    respond 200 with:
      success: true
      count: mentors.length
      data: { mentors }
```

### Chatbot Controller & Routes

```text
chatbotRoutes:
  storage = multer.memoryStorage()
  upload = multer({ storage, limits: { fileSize: 5MB } })

  POST "/chat":
    middlewares: protect, upload.single("file")
    handler: chat

  GET "/models":
    middlewares: protect
    handler: getModels
```

```text
chat(req, res):
  { message, conversationHistory = [], mode = "student-helper" } = body
  contextData = ""

  if req.file exists:
    isPDF = check mimetype, extension ".pdf", or magic bytes "%PDF"
    if not isPDF:
      respond 400 "Only PDF files are currently supported"

    try:
      contextData = extractTextFromPDF(req.file.buffer)
      if empty:
        respond 400 "PDF appears to be empty or unreadable"
    catch pdfError:
      respond 400 "Failed to read PDF file: <details>"

  if (message missing or blank) AND no file:
    respond 400 "Message is required unless uploading a file"

  parsedHistory =
    if typeof conversationHistory == "string":
      JSON.parse(conversationHistory)
    else:
      conversationHistory

  result = getChatbotResponse(
    message or "Please analyze this document.",
    parsedHistory,
    mode,
    contextData
  )

  if !result.success:
    respond 500 with { success: false, message, error }
  else:
    respond 200 with:
      success: true
      data: {
        response: result.message,
        model: result.model or "unknown",
        usage: result.usage or {}
      }
```

```text
getModels(req, res):
  models = getAvailableModels()
  recommended = env.GROQ_API_KEY ? "groq" : "ollama"

  respond 200 with:
    success: true
    data: { models, recommended }
```

